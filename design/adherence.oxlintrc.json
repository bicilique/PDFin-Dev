{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/tool/**",
              "components/workspace/**",
              "ui_kits/pdfin-web/**",
              "ui_kits/pdfin-web/workspace/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Plus Jakarta Sans|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Plus Jakarta Sans, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Alert'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|title|children|key|ref|className|style|children)$/]",
        "message": "<Alert> doesn't accept that prop. Declared props: tone, title, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Alert'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:info|success|warning|error)$/]",
        "message": "<Alert> tone must be one of 'info' | 'success' | 'warning' | 'error'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|brand|success|warning|error|info)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'brand' | 'success' | 'warning' | 'error' | 'info'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|disabled|fullWidth|icon|children|onClick|type|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, disabled, fullWidth, icon, children, onClick, type."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit)$/]",
        "message": "<Button> type must be one of 'button' | 'submit'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:raised|padding|style|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: raised, padding, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='ContextMenuItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|icon|shortcut|danger|disabled|onSelect|key|ref|className|style|children)$/]",
        "message": "<ContextMenuItem> doesn't accept that prop. Declared props: label, icon, shortcut, danger, disabled, onSelect."
      },
      {
        "selector": "JSXOpeningElement[name.name='DownloadCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|meta|downloadLabel|onDownload|icon|key|ref|className|style|children)$/]",
        "message": "<DownloadCard> doesn't accept that prop. Declared props: name, meta, downloadLabel, onDownload, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='Dropzone'] > JSXAttribute > JSXIdentifier[name!=/^(?:lang|multiple|accept|onSelect|compact|key|ref|className|style|children)$/]",
        "message": "<Dropzone> doesn't accept that prop. Declared props: lang, multiple, accept, onSelect, compact."
      },
      {
        "selector": "JSXOpeningElement[name.name='Dropzone'] > JSXAttribute[name.name='lang'] > Literal[value!=/^(?:id|en)$/]",
        "message": "<Dropzone> lang must be one of 'id' | 'en'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FileCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|meta|thumbnail|onRemove|dragHandle|removeLabel|key|ref|className|style|children)$/]",
        "message": "<FileCard> doesn't accept that prop. Declared props: name, meta, thumbnail, onRemove, dragHandle, removeLabel."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|icon|variant|size|disabled|onClick|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: label, icon, variant, size, disabled, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:ghost|outline)$/]",
        "message": "<IconButton> variant must be one of 'ghost' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<IconButton> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|id|error|hint|mono|placeholder|value|onChange|type|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, id, error, hint, mono, placeholder, value, onChange, type."
      },
      {
        "selector": "JSXOpeningElement[name.name='LangSwitcher'] > JSXAttribute > JSXIdentifier[name!=/^(?:lang|onChange|key|ref|className|style|children)$/]",
        "message": "<LangSwitcher> doesn't accept that prop. Declared props: lang, onChange."
      },
      {
        "selector": "JSXOpeningElement[name.name='LangSwitcher'] > JSXAttribute[name.name='lang'] > Literal[value!=/^(?:id|en)$/]",
        "message": "<LangSwitcher> lang must be one of 'id' | 'en'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Modal'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|children|footer|onClose|width|key|ref|className|style|children)$/]",
        "message": "<Modal> doesn't accept that prop. Declared props: title, children, footer, onClose, width."
      },
      {
        "selector": "JSXOpeningElement[name.name='PageCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:pageNumber|selected|rotation|children|width|onClick|onContextMenu|badge|actions|dimmed|label|key|ref|className|style|children)$/]",
        "message": "<PageCard> doesn't accept that prop. Declared props: pageNumber, selected, rotation, children, width, onClick, onContextMenu, badge, actions, dimmed, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='PageNavigator'] > JSXAttribute > JSXIdentifier[name!=/^(?:page|count|onChange|prevLabel|nextLabel|key|ref|className|style|children)$/]",
        "message": "<PageNavigator> doesn't accept that prop. Declared props: page, count, onChange, prevLabel, nextLabel."
      },
      {
        "selector": "JSXOpeningElement[name.name='PrivacyPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:lang|text|key|ref|className|style|children)$/]",
        "message": "<PrivacyPill> doesn't accept that prop. Declared props: lang, text."
      },
      {
        "selector": "JSXOpeningElement[name.name='PrivacyPill'] > JSXAttribute[name.name='lang'] > Literal[value!=/^(?:id|en)$/]",
        "message": "<PrivacyPill> lang must be one of 'id' | 'en'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<ProgressBar> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Select'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|id|options|value|onChange|key|ref|className|style|children)$/]",
        "message": "<Select> doesn't accept that prop. Declared props: label, id, options, value, onChange."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|checked|onChange|disabled|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: label, checked, onChange, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|children|action|onDismiss|key|ref|className|style|children)$/]",
        "message": "<Toast> doesn't accept that prop. Declared props: tone, children, action, onDismiss."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|success|error|info)$/]",
        "message": "<Toast> tone must be one of 'neutral' | 'success' | 'error' | 'info'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toolbar'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|style|key|ref|className|style|children)$/]",
        "message": "<Toolbar> doesn't accept that prop. Declared props: children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ToolTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|description|href|badge|key|ref|className|style|children)$/]",
        "message": "<ToolTile> doesn't accept that prop. Declared props: icon, title, description, href, badge."
      },
      {
        "selector": "JSXOpeningElement[name.name='ZoomControl'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onZoomIn|onZoomOut|onReset|min|max|key|ref|className|style|children)$/]",
        "message": "<ZoomControl> doesn't accept that prop. Declared props: value, onZoomIn, onZoomOut, onReset, min, max."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
